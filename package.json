{
  "name": "emptyCLI",
  "version": "1.0.0",
  "description": "Blueprint for CLI",
  "bin": {
    "YOUR_COMMAND_HERE": "./bin/YOUR_CLI_NAME_HERE.js"
  },
  "scripts": {
    "_compile": "tsc",
    "_compile.watch": "tsc --watch",
    "_copyfiles": "copyfiles --up 1 \"./src/**/*.!(mts|ts)\" dist",
    "abgabe": "ziplocalgit zip -f myCLI.zip --addCopilotHistory --remotePath /workspaces",
    "ailog": "copilothistory export -o ailog.md --remotePath /workspaces",
    "build": "npm run pretest",
    "clean": "rimraf --glob dist out coverage junit.xml abgabe*.",
    "pretest": "npm-run-all -c _compile _copyfiles",
    "test": "jest --runInBand"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "copilothistory": "^3.0.3",
    "copyfiles": "2.4.1",
    "cross-env": "10.1.0",
    "jest": "30.3.0",
    "jest-junit": "16.0.0",
    "npm-run-all": "4.1.5",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "ziplocalgit": "^2.0.2"
  },
  "dependencies": {
    "commander": "^15.0.0"
  }
}
